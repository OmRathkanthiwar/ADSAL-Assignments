import java.util.*;

class Job {
    String jobName;
    int time;

    Job(String jobName, int time) {
        this.jobName = jobName;
        this.time = time;
    }
}

public class JobScheduler {

    private ArrayList<Job> heap;

    public JobScheduler() {
        heap = new ArrayList<>();
    }

    private int parent(int i) {
        return (i - 1) / 2;
    }

    private int leftChild(int i) {
        return 2 * i + 1;
    }

    private int rightChild(int i) {
        return 2 * i + 2;
    }

    private void swap(int i, int j) {
        Job temp = heap.get(i);
        heap.set(i, heap.get(j));
        heap.set(j, temp);
    }

    private void heapifyUp(int index) {

        while (index > 0 && heap.get(index).time > heap.get(parent(index)).time) {
            swap(index, parent(index));
            index = parent(index);
        }
    }

    public void insertProcess(String jobName, int time) {

        Job newJob = new Job(jobName, time);

        heap.add(newJob);

        heapifyUp(heap.size() - 1);

        System.out.println("Job inserted: " + jobName + " (" + time + ")");
    }

    public void displayHeap() {

        if (heap.isEmpty()) {
            System.out.println("Heap is empty");
            return;
        }

        System.out.println("Heap (Level Order):");
        for (int i = 0; i < heap.size(); i++) {
            System.out.println(heap.get(i).jobName + " (" + heap.get(i).time + ")");
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        JobScheduler scheduler = new JobScheduler();

        int choice;

        do {
            System.out.println("\n1. Insert Job");
            System.out.println("2. Display Heap");
            System.out.println("3. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {

                case 1:
                    sc.nextLine();
                    System.out.print("Enter Job Name: ");
                    String name = sc.nextLine();
                    System.out.print("Enter Execution Time: ");
                    int time = sc.nextInt();
                    scheduler.insertProcess(name, time);
                    break;

                case 2:
                    scheduler.displayHeap();
                    break;

                case 3:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice");
            }

        } while (choice != 3);

        sc.close();
    }
}
