import java.util.*;

public class MinJobScheduler {

    private ArrayList<Job> heap;

    public MinJobScheduler() {
        heap = new ArrayList<>();
    }

    private int parent(int i) {
        return (i - 1) / 2;
    }

    private int leftChild(int i) {
        return 2 * i + 1;
    }

    private int rightChild(int i) {
        return 2 * i + 2;
    }

    private void swap(int i, int j) {
        Job temp = heap.get(i);
        heap.set(i, heap.get(j));
        heap.set(j, temp);
    }

    private void heapifyUp(int index) {
        while (index > 0 &&
                heap.get(index).time < heap.get(parent(index)).time) {
            swap(index, parent(index));
            index = parent(index);
        }
    }

    private void heapifyDown(int index) {

        int smallest = index;
        int left = leftChild(index);
        int right = rightChild(index);

        if (left < heap.size() &&
                heap.get(left).time < heap.get(smallest).time) {
            smallest = left;
        }

        if (right < heap.size() &&
                heap.get(right).time < heap.get(smallest).time) {
            smallest = right;
        }

        if (smallest != index) {
            swap(index, smallest);
            heapifyDown(smallest);
        }
    }

    public void insertProcess(String jobName, int time) {

        Job newJob = new Job(jobName, time);
        heap.add(newJob);

        heapifyUp(heap.size() - 1);

        System.out.println("Job inserted: " + jobName + " (" + time + ")");
    }

    public void deleteProcess() {

        if (heap.isEmpty()) {
            System.out.println("Heap is empty");
            return;
        }

        Job rootJob = heap.get(0);

        Job lastJob = heap.get(heap.size() - 1);
        heap.set(0, lastJob);
        heap.remove(heap.size() - 1);

        heapifyDown(0);

        System.out.println("Deleted Job: " + rootJob.jobName +
                " (" + rootJob.time + ")");
    }

    public void displayHeap() {

        if (heap.isEmpty()) {
            System.out.println("Heap is empty");
            return;
        }

        System.out.println("Heap (Level Order):");
        for (int i = 0; i < heap.size(); i++) {
            System.out.println(heap.get(i).jobName +
                    " (" + heap.get(i).time + ")");
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        MinJobScheduler scheduler = new MinJobScheduler();

        int choice;

        do {
            System.out.println("\n1. Insert Job");
            System.out.println("2. Delete Highest Priority Job");
            System.out.println("3. Display Heap");
            System.out.println("4. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {

                case 1:
                    sc.nextLine();
                    System.out.print("Enter Job Name: ");
                    String name = sc.nextLine();
                    System.out.print("Enter Execution Time: ");
                    int time = sc.nextInt();
                    scheduler.insertProcess(name, time);
                    break;

                case 2:
                    scheduler.deleteProcess();
                    break;

                case 3:
                    scheduler.displayHeap();
                    break;

                case 4:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice");
            }

        } while (choice != 4);

        sc.close();
    }
}
